#!/bin/bash
###############################################################################
# CScript configure file
#
# Creates the Makefile for build.mk
###############################################################################

# Options / Modes
target=rel
ansi_strict=0

# Get options
for arg; do
	case $(echo "$arg" | tr '[:upper:]' '[:lower:]') in
		"--ansi-strict")
			ansi_strict=1
			;;
	esac
done

# Get mode
if [[ "$#" -gt 0 ]]; then
	for last; do true; done
	case $(echo "$last" | tr '[:upper:]' '[:lower:]') in
		"release" | "r" | "rel")
			target=rel
			;;
		"debug" | "dbg" | "d")
			target=dbg
			;;
		"delete-makefile")
			rm -f Makefile
			exit 0
			;;
		*)
			echo "\
usage: configure.sh [options] <release | debug | delete-makefile>

modes:
	release				For release mode
	debug				For debug mode
	delete-makefile		Deletes the generated makefile

options:
	--ansi-strict		Compiles in strict c89 mode"
			exit 0
			;;
	esac
fi

echo "\
###############################################################################
# GENERATED BY CONFIGURE
#
# This file is just a head to include compile.mk
###############################################################################

BUILD_MODE		:=$target
ANSI_STRICT		:=$ansi_strict

# Library settings
LIB				:=cunsc
TARGET			 =build_$target/cuns/lib\$(LIB).so
SRC_DIR			:=src
TARGET_DIR		:=build_$target/cuns

# Test settings
TEST_TARGET		 =build_$target/test/test_lib\$(LIB)
TEST_DIR		:=tests
TEST_TARGET_DIR	:=build_$target/test

include build.mk
" > Makefile

