extern fn print_i32(val: i32);
extern fn input_i32() -> i32;

fn print_until(n: i32) {
    for x in (0..n) {
        print_i32(x);
    }
}

fn main() -> b8 {
    let x = 8 + input_i32();
    print_until(x);
    return true;
}

