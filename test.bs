
let str = "hello";

extern fn print_i32(val: i32);
extern fn input_i32() -> i32;
extern fn rand() -> u16;
extern fn print_c8str(str: &[c8]);


let num = 69;

fn main() -> b8 {
    num = rand() % 100;

    let guess = 0;
    while (true) {
        guess = input_i32();
        if (guess == num) {
            return true;
        } else if (guess > num) {
            print_i32(1);
        } else {
            print_i32(-1);
        }
    }
    return true;
}

